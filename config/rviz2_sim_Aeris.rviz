      Class: rviz_default_plugins/PointCloud2
      Color: 200; 200; 200
      Color Transformer: AxisColor
      Decay Time: 0.10000000149011612
      Enabled: false
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 255
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: Rohscan (Ouster)
      Position Transformer: XYZ
      Selectable: true
